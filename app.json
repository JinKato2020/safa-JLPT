{
  "expo": {
    "name": "まいにちJLPT",
    "slug": "safa-jlpt",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "safajlpt",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": "1.1.1",
    "updates": {
      "url": "https://u.expo.dev/3590a434-66c9-4282-be7e-1f1c9d021c79"
    },
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.safa.jlpt",
      "buildNumber": "3",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.safa.english",
      "versionCode": 2001,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#2563eb"
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "3590a434-66c9-4282-be7e-1f1c9d021c79"
      }
    },
    "owner": "jinkato1914"
  }
}
